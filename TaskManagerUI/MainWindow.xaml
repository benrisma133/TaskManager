<Window x:Class="TaskManagerUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:helpers="clr-namespace:TaskManagerUI.Helpers"
        xmlns:controls="clr-namespace:TaskManagerUI.Controls.Components"
        mc:Ignorable="d"
        Title="TaskFlow"
        Height="700" Width="1200"
        MinHeight="600" MinWidth="952"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        Icon="Assets/TaskFlow_Icon.png">

    <Window.Resources>
        <!-- Add inside your existing ResourceDictionary -->
        <DropShadowEffect x:Key="ShadowEffect"
                  BlurRadius="12"
                  ShadowDepth="2"
                  Direction="315"
                  Color="#000000"
                  Opacity="0.25"/>

        <Style TargetType="Window">
            <Setter Property="shell:WindowChrome.WindowChrome">
                <Setter.Value>
                    <shell:WindowChrome
                    ResizeBorderThickness="6"
                    CaptionHeight="0"
                    CornerRadius="0"
                    GlassFrameThickness="0"
                    UseAeroCaptionButtons="False"/>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>



        <Border Background="{DynamicResource AppBackgroundBrush}"
            CornerRadius="12"
            ClipToBounds="True"
                Padding="4">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="52"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ══════════════════════════════════════════════ -->
                <!--                  TITLE BAR                    -->
                <!-- ══════════════════════════════════════════════ -->
                <Border Grid.Row="0"
                    Background="{DynamicResource SidebarBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12 ,12 ,0 ,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">

                    <Grid Margin="16,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Logo -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <!-- Logo Icon with Gradient -->
                            <Border CornerRadius="8"
                                    Width="30" Height="30"
                                    Margin="0,0,10,0">

                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                        <GradientStop Color="#3B82F6" Offset="0"/>
                                        <GradientStop Color="#2563EB" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>

                                <Viewbox Width="18" Height="18">
                                    <Canvas Width="24" Height="24">

                                        <!-- Clipboard background -->
                                        <Rectangle Canvas.Left="5" Canvas.Top="3" 
                                                      Width="14" Height="18" 
                                                      RadiusX="1.5" RadiusY="1.5" 
                                                      Fill="White" 
                                                      Opacity="0.95"/>

                                        <!-- Clipboard clip -->
                                        <Rectangle Canvas.Left="9" Canvas.Top="1" 
                                                      Width="6" Height="2.5" 
                                                      RadiusX="1" RadiusY="1" 
                                                      Fill="White" 
                                                      Opacity="0.7"/>

                                        <!-- Checkmark 1 - Completed -->
                                        <Ellipse Canvas.Left="7" Canvas.Top="7" 
                                                Width="3" Height="3" 
                                                Fill="#10B981"/>
                                        <Path Data="M 7.8,8.3 L 8.3,8.8 L 9.5,7.5" 
                                              Stroke="White" 
                                              StrokeThickness="0.8" 
                                              StrokeStartLineCap="Round" 
                                              StrokeEndLineCap="Round" 
                                              StrokeLineJoin="Round"/>

                                        <Line X1="11" Y1="8.5" X2="17" Y2="8.5" 
                                              Stroke="#CBD5E0" 
                                              StrokeThickness="0.8" 
                                              StrokeStartLineCap="Round"/>

                                        <!-- Checkmark 2 - Completed -->
                                        <Ellipse Canvas.Left="7" Canvas.Top="11" 
                                                    Width="3" Height="3" 
                                                    Fill="#10B981"/>
                                        <Path Data="M 7.8,12.3 L 8.3,12.8 L 9.5,11.5" 
                                              Stroke="White" 
                                              StrokeThickness="0.8" 
                                              StrokeStartLineCap="Round" 
                                              StrokeEndLineCap="Round" 
                                              StrokeLineJoin="Round"/>

                                        <Line X1="11" Y1="12.5" X2="17" Y2="12.5" 
                                              Stroke="#CBD5E0" 
                                              StrokeThickness="0.8" 
                                              StrokeStartLineCap="Round"/>

                                        <!-- Empty checkbox - Pending -->
                                        <Ellipse Canvas.Left="7" Canvas.Top="15" 
                                                Width="3" Height="3" 
                                                Stroke="#94A3B8" 
                                                StrokeThickness="0.6" 
                                                Fill="Transparent"/>

                                        <Line X1="11" Y1="16.5" X2="15" Y2="16.5" 
                                              Stroke="#E2E8F0" 
                                              StrokeThickness="0.8" 
                                              StrokeStartLineCap="Round"/>

                                    </Canvas>
                                </Viewbox>
                            </Border>

                            <!-- Text -->
                            <TextBlock Text="TaskFlow"
                                       FontSize="15"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <!-- Right: Notification + Settings + Profile + Window Controls -->
                        <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center">

                            <!-- Notification -->
                            <Button x:Name="BtnNotification"
                                Style="{DynamicResource IconButton}"
                                Margin="0,0,4,0"
                                ToolTip="Notifications"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <Viewbox Width="16" Height="16">
                                    <Path Data="{StaticResource IconNotification}"
                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      Stretch="Uniform"/>
                                </Viewbox>
                            </Button>

                            <!-- Profile -->
                            <Button x:Name="BtnProfile"
                                Style="{DynamicResource IconButton}"
                                Margin="0,0,12,0"
                                ToolTip="Profile"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <Viewbox Width="16" Height="16">
                                    <Path Data="{StaticResource IconUser}"
                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                      StrokeThickness="1.8"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Fill="Transparent"
                                      Stretch="Uniform"/>
                                </Viewbox>
                            </Button>

                            <!-- Separator -->
                            <Border Width="1"
                                Height="20"
                                Background="{DynamicResource BorderDefaultBrush}"
                                Margin="0,0,12,0"/>

                            <!-- Minimize -->
                            <Button x:Name="BtnMinimize"
                                Width="32" Height="32"
                                Margin="0,0,2,0"
                                ToolTip="Minimize"
                                Click="BtnMinimize_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                            Background="Transparent"
                                            CornerRadius="6">
                                            <Viewbox Width="12" Height="12">
                                                <Path Data="{StaticResource IconMinimize}"
                                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Stretch="Uniform"/>
                                            </Viewbox>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource MenuHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Maximize -->
                            <Button x:Name="BtnMaximize"
                                Width="32" Height="32"
                                Margin="0,0,2,0"
                                ToolTip="Maximize"
                                Click="BtnMaximize_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                            Background="Transparent"
                                            CornerRadius="6">
                                            <Viewbox Width="12" Height="12">
                                                <Path x:Name="MaxIcon"
                                                  Data="{StaticResource IconMaximize}"
                                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                                  StrokeThickness="2"
                                                  StrokeLineJoin="Round"
                                                  Stretch="Uniform"/>
                                            </Viewbox>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource MenuHoverBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <!-- Close -->
                            <Button x:Name="BtnClose"
                                Width="32" Height="32"
                                ToolTip="Close"
                                Click="BtnClose_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd"
                                            Background="Transparent"
                                            CornerRadius="6">
                                            <Viewbox Width="12" Height="12">
                                                <Path Data="{StaticResource IconClose}"
                                                  Stroke="{DynamicResource TextSecondaryBrush}"
                                                  StrokeThickness="2"
                                                  StrokeStartLineCap="Round"
                                                  StrokeEndLineCap="Round"
                                                  Stretch="Uniform"/>
                                            </Viewbox>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background"
                                                    Value="{DynamicResource ErrorBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ══════════════════════════════════════════════ -->
                <!--              MAIN AREA (Sidebar + Content)    -->
                <!-- ══════════════════════════════════════════════ -->
                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- ══════════════════════════════════════════ -->
                    <!--                  SIDEBAR                  -->
                    <!-- ══════════════════════════════════════════ -->
                    <Border Grid.Column="0"
                        CornerRadius="0,0,0,12"
                        Background="{DynamicResource SidebarBackgroundBrush}"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,0,1,0"
                        ClipToBounds="True"
                        MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="60"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Hamburger -->
                            <Border Grid.Row="0"
                                    Padding="12,10"
                                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                                    BorderThickness="0,0,0,1">
                                <Button x:Name="HamburgerBtn"
                                        HorizontalAlignment="Left"
                                        Width="34" Height="34"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        Click="HamburgerBtn_Click">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="Bd"
                                                Background="Transparent"
                                                CornerRadius="8">
                                                <Viewbox Width="18" Height="18">
                                                    <Path x:Name="HamburgerPath"
                                                      Data="{StaticResource IconSidebar}"
                                                      Stroke="{DynamicResource TextSecondaryBrush}"
                                                      StrokeThickness="1.8"
                                                      StrokeStartLineCap="Round"
                                                      StrokeEndLineCap="Round"
                                                      Fill="Transparent"
                                                      Stretch="Uniform"/>
                                                </Viewbox>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd" Property="Background"
                                                        Value="{DynamicResource MenuHoverBrush}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Border>

                            <!-- Menu Items -->
                            <StackPanel Grid.Row="1" Margin="10,16,10,0">

                                <!-- ═══ HOME ═══ -->
                                <Grid>
                                    <Button x:Name="BtnHome"
                                        Style="{DynamicResource MenuButton}"
                                        Click="BtnHome_Click"
                                        MouseEnter="MenuBtn_MouseEnter"
                                        MouseLeave="MenuBtn_MouseLeave"
                                        Tag="Home">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                                                <Path Data="{StaticResource IconDashboard}"
                                                  Fill="{Binding Foreground, 
                                                         RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Stretch="Uniform"/>
                                            </Viewbox>
                                            <TextBlock x:Name="HomeText"
                                                   Grid.Column="1"
                                                   Text="Home"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Margin="10,0,0,0"/>
                                        </Grid>
                                    </Button>

                                    <!-- Tooltip Popup -->
                                    <Popup x:Name="PopupHome"
                                       PlacementTarget="{Binding ElementName=BtnHome}"
                                       Placement="Right"
                                       AllowsTransparency="True"
                                       IsHitTestVisible="False"
                                       PopupAnimation="None"
                                       StaysOpen="True"
                                       VerticalOffset="8">
                                        <controls:SidebarToolTip Title="Home"/>
                                    </Popup>
                                </Grid>

                                <!-- ═══ PROJECTS ═══ -->
                                <Grid>
                                    <Button x:Name="BtnProjects"
                                        Style="{DynamicResource MenuButton}"
                                        Click="BtnProjects_Click"
                                        MouseEnter="MenuBtn_MouseEnter"
                                        MouseLeave="MenuBtn_MouseLeave"
                                        Tag="Projects">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                                                <Path Data="{StaticResource IconFolder}"
                                                  Fill="{Binding Foreground, 
                                                         RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Stretch="Uniform"/>
                                            </Viewbox>
                                            <TextBlock x:Name="ProjectsText"
                                                   Grid.Column="1"
                                                   Text="Projects"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Margin="10,0,0,0"/>
                                        </Grid>
                                    </Button>

                                    <Popup x:Name="PopupProjects"
                                       PlacementTarget="{Binding ElementName=BtnProjects}"
                                       Placement="Right"
                                       AllowsTransparency="True"
                                       IsHitTestVisible="False"
                                       PopupAnimation="None"
                                       StaysOpen="True"
                                       VerticalOffset="8">
                                        <controls:SidebarToolTip Title="Projects"/>
                                    </Popup>
                                </Grid>

                                <!-- ═══ TASKS ═══ -->
                                <Grid>
                                    <Button x:Name="BtnTasks"
            Style="{DynamicResource MenuButton}"
            Click="BtnTasks_Click"
            MouseEnter="MenuBtn_MouseEnter"
            MouseLeave="MenuBtn_MouseLeave"
            Tag="Tasks">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                                                <Path Data="{StaticResource IconTasks}"
                      Stroke="{Binding Foreground,
                               RelativeSource={RelativeSource AncestorType=Button}}"
                      StrokeThickness="1.8"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      Fill="Transparent"
                      Stretch="Uniform"/>
                                            </Viewbox>

                                            <TextBlock x:Name="TasksText"
                       Grid.Column="1"
                       Text="Tasks"
                       VerticalAlignment="Center"
                       FontSize="14"
                       Margin="10,0,0,0"/>
                                        </Grid>
                                    </Button>

                                    <!-- ── Pulsing session dot ─────────────────────────────── -->
                                    <Ellipse x:Name="SessionDot"
             Width="10"
             Height="10"
             Fill="{DynamicResource SuccessBrush}"
             HorizontalAlignment="Left"
             VerticalAlignment="Top"
             Margin="28,-2,0,0"
             Visibility="Collapsed"
             IsHitTestVisible="False">
                                        <Ellipse.Triggers>
                                            <EventTrigger RoutedEvent="Loaded">
                                                <BeginStoryboard>
                                                    <Storyboard RepeatBehavior="Forever">
                                                        <DoubleAnimation Storyboard.TargetName="SessionDot"
                                         Storyboard.TargetProperty="Opacity"
                                         From="1.0" To="0.2"
                                         Duration="0:0:0.8"
                                         AutoReverse="True"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </EventTrigger>
                                        </Ellipse.Triggers>
                                    </Ellipse>

                                    <Popup x:Name="PopupTasks"
           PlacementTarget="{Binding ElementName=BtnTasks}"
           Placement="Right"
           AllowsTransparency="True"
           IsHitTestVisible="False"
           PopupAnimation="None"
           StaysOpen="True"
           VerticalOffset="8">
                                        <controls:SidebarToolTip Title="Tasks"/>
                                    </Popup>
                                </Grid>

                                <!-- ═══ CATEGORIES ═══ -->
                                <Grid>
                                    <Button x:Name="BtnCategories"
                                        Style="{DynamicResource MenuButton}"
                                        Click="BtnCategories_Click"
                                        MouseEnter="MenuBtn_MouseEnter"
                                        MouseLeave="MenuBtn_MouseLeave"
                                        Tag="Categories">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                                                <Path Data="{StaticResource IconCategories}"
                                                  Fill="{Binding Foreground, 
                                                         RelativeSource={RelativeSource AncestorType=Button}}"
                                                  Stretch="Uniform"/>
                                            </Viewbox>
                                            <TextBlock x:Name="CategoriesText"
                                                   Grid.Column="1"
                                                   Text="Categories"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Margin="10,0,0,0"/>
                                        </Grid>
                                    </Button>

                                    <Popup x:Name="PopupCategories"
                                       PlacementTarget="{Binding ElementName=BtnCategories}"
                                       Placement="Right"
                                       AllowsTransparency="True"
                                       IsHitTestVisible="False"
                                       PopupAnimation="None"
                                       StaysOpen="True"
                                       VerticalOffset="8">
                                        <controls:SidebarToolTip Title="Categories"/>
                                    </Popup>
                                </Grid>

                                <!-- Divider -->
                                <Border Height="1"
                                    Background="{DynamicResource BorderDefaultBrush}"
                                    Margin="0,12"/>

                                <!-- ═══ SETTINGS ═══ -->
                                <Grid>
                                    <Button x:Name="BtnSettings"
                                        Style="{DynamicResource MenuButton}"
                                        Click="BtnSettings_Click"
                                        MouseEnter="MenuBtn_MouseEnter"
                                        MouseLeave="MenuBtn_MouseLeave"
                                        Tag="Settings">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="24"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                                                <Path Data="{StaticResource IconSettings}"
                                                  Stroke="{Binding Foreground, 
                                                           RelativeSource={RelativeSource AncestorType=Button}}"
                                                  StrokeThickness="1.8"
                                                  Fill="Transparent"
                                                  Stretch="Uniform"/>
                                            </Viewbox>
                                            <TextBlock x:Name="SettingsText"
                                                   Grid.Column="1"
                                                   Text="Settings"
                                                   VerticalAlignment="Center"
                                                   FontSize="14"
                                                   Margin="10,0,0,0"/>
                                        </Grid>
                                    </Button>

                                    <Popup x:Name="PopupSettings"
                                       PlacementTarget="{Binding ElementName=BtnSettings}"
                                       Placement="Right"
                                       AllowsTransparency="True"
                                       IsHitTestVisible="False"
                                       PopupAnimation="None"
                                       StaysOpen="True"
                                       VerticalOffset="8">
                                        <controls:SidebarToolTip Title="Settings"/>
                                    </Popup>
                                </Grid>

                            </StackPanel>
                            
                            <!-- Profile -->
                            <Border Grid.Row="2"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="0,1,0,0"
                                Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="36"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Background="{DynamicResource AccentLightBrush}"
                                        CornerRadius="18"
                                        Width="32" Height="32"
                                        HorizontalAlignment="Center">
                                        <TextBlock Text="I"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource AccentBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                    </Border>

                                    <StackPanel x:Name="ProfileStack"
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Margin="8,0,0,0">
                                        <TextBlock Text="Ismail"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Text="Developer"
                                               FontSize="11"
                                               Foreground="{DynamicResource TextMutedBrush}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                        </Grid>
                    </Border>

                    <!-- ══════════════════════════════════════════ -->
                    <!--          CONTENT AREA WITH HEADER         -->
                    <!-- ══════════════════════════════════════════ -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <!-- Page Header -->
                            <RowDefinition Height="*"/>
                            <!-- Page Content -->
                        </Grid.RowDefinitions>

                        <!-- ═══ PAGE HEADER ═══ -->
                        <Border Grid.Row="0"
                                Background="{DynamicResource SidebarBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="20,12"
                                Height="60">
                            <TextBlock x:Name="PageTitle"
                                       Text="Categories"
                                       VerticalAlignment="Top"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </Border>

                        <!-- ═══ PAGE CONTENT ═══ -->
                        <Border Grid.Row="1"
                                CornerRadius="0,0,12,0"
                                Background="{DynamicResource SidebarBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="0,0,1,0"
                                ClipToBounds="True">
                            <ContentPresenter x:Name="PageContent"/>
                        </Border>
                    </Grid>


                </Grid>
            </Grid>
        </Border>

    </Grid>
</Window>