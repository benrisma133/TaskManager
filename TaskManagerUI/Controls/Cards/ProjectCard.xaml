<UserControl x:Class="TaskManagerUI.Controls.Cards.ProjectCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TaskManagerUI.Controls.Cards"
             xmlns:components="clr-namespace:TaskManagerUI.Controls.Components"
             mc:Ignorable="d" 
             x:Name="Root">

    <Border x:Name="CardBorder"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="20"
            HorizontalAlignment="Stretch"
            Margin="0"
            RenderTransformOrigin="0.5,0.5">

        <Border.RenderTransform>
            <TranslateTransform x:Name="CardTranslate"/>
        </Border.RenderTransform>

        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                         Storyboard.TargetProperty="Y"
                                         To="-2"
                                         Duration="0:0:0.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                         Storyboard.TargetProperty="Y"
                                         To="0"
                                         Duration="0:0:0.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Border.Effect>
            <DropShadowEffect
                    x:Name="CardShadow"
                    Color="#C39BD3"
                    BlurRadius="30"
                    ShadowDepth="5"
                    Opacity="0.4"/>
        </Border.Effect>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Row 0: Icon + Title + Category -->
                <RowDefinition Height="12"/>
                <!-- Row 1: Divider -->
                <RowDefinition Height="Auto"/>
                <!-- Row 2: Priority + DueDate + DaysLeft -->
                <RowDefinition Height="12"/>
                <!-- Row 3: Divider -->
                <RowDefinition Height="Auto"/>
                <!-- Row 4: Progress label + ProgressBar -->
                <RowDefinition Height="12"/>
                <!-- Row 5: Divider -->
                <RowDefinition Height="Auto"/>
                <!-- Row 6: Status badge + Edit/Delete -->
            </Grid.RowDefinitions>

            <!-- ROW 0: Icon + Title -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CHANGED: Fixed size, padding, background bound to AccentBrush via ElementName -->
                <Border x:Name="IconBg"
                        Width="44" Height="44"
                        CornerRadius="10"
                        Padding="10"
                        Background="{DynamicResource AccentBrush}">

                    <!-- CHANGED: Removed Canvas+ScaleTransform, using simple Viewbox with Stretch -->
                    <Viewbox>
                        <!-- CHANGED: Fill=White so icon is always visible on colored background -->
                        <!-- CHANGED: ElementName=Root for reliable binding instead of AncestorType -->
                        <!-- CHANGED: Added Stretch=Uniform so icon scales correctly -->
                        <Path x:Name="IconPath"
                              Stroke="White"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Data="{StaticResource IconWeb}"/>
                    </Viewbox>

                </Border>

                <!-- CHANGED: FontSize from 18 to 14 — 18 was too large for a stat card -->
                <!-- Name + Type stack -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock x:Name="NameText"
                               Text="E-commerce Platform"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock x:Name="TypeText"
                               Text="Web App"
                               FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>

            </Grid>

            <!-- ROW 2: Divider -->
            <Border Grid.Row="1"
                    Height="1"
                    Background="{DynamicResource BorderDefaultBrush}"
                    VerticalAlignment="Center"/>


            <!-- ROW 3: Priority + DueDate + DaysLeft  -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- COLUMN 0: Priority -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">

                    <TextBlock Text="Priority"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                    <Border Height="4"/>

                    <!-- PriorityBadge -->
                    <components:PriorityBadge x:Name="PriorityBadge" 
                                              Margin="0,3,0,0" 
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Status="Critical"/>


                </StackPanel>

                <Border Grid.Column="1"/>

                <!-- COLUMN 1: Grade -->
                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="Due Date"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                    <Border Height="4"/>

                    <TextBlock x:Name="DueDateText"
                               Text="May 15"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,6,0,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Column="3"/>

                <!-- COLUMN 2: DaysLeft -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Days Left"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                    <Border Height="4"/>

                    <TextBlock x:Name="DaysLeftText"
                               Text="3d left"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,6,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

            </Grid>

            <!-- ROW 2: Divider -->
            <Border Grid.Row="3"
                    Height="1"
                    Background="{DynamicResource BorderDefaultBrush}"
                    VerticalAlignment="Center"/>

        </Grid>


    </Border>
    
</UserControl>
