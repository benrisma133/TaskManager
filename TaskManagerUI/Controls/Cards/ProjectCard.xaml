<UserControl x:Class="TaskManagerUI.Controls.Cards.ProjectCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TaskManagerUI.Controls.Cards"
             xmlns:components="clr-namespace:TaskManagerUI.Controls.Components"
             mc:Ignorable="d" 
             x:Name="Root">

    <Border x:Name="CardBorder"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="20"
            HorizontalAlignment="Stretch"
            Margin="0"
            RenderTransformOrigin="0.5,0.5">

        <Border.RenderTransform>
            <TranslateTransform x:Name="CardTranslate"/>
        </Border.RenderTransform>

        <Border.Triggers>
            <EventTrigger RoutedEvent="MouseEnter">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                         Storyboard.TargetProperty="Y"
                                         To="-2"
                                         Duration="0:0:0.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
            <EventTrigger RoutedEvent="MouseLeave">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                         Storyboard.TargetProperty="Y"
                                         To="0"
                                         Duration="0:0:0.2"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Border.Triggers>

        <Border.Effect>
            <DropShadowEffect x:Name="CardShadow"
                      Color="#000000"
                      Direction="270"
                      ShadowDepth="2"
                      BlurRadius="8"
                      Opacity="0.15"
                      RenderingBias="Performance"/>
        </Border.Effect>

        <Grid>

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Row 0: Icon + Title + Category -->
                <RowDefinition Height="12"/>
                <!-- Row 1: Divider -->
                <RowDefinition Height="Auto"/>
                <!-- Row 2: Priority + DueDate + DaysLeft -->
                <RowDefinition Height="12"/>
                <!-- Row 3: Divider -->
                <RowDefinition Height="Auto"/>
                <!-- Row 4: Progress label + ProgressBar -->
                <RowDefinition Height="12"/>
                <!-- Row 5: Divider -->
                <RowDefinition Height="Auto"/>
                <!-- Row 6: Status badge + Edit/Delete -->
            </Grid.RowDefinitions>

            <!-- ROW 0: Icon + Title -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CHANGED: Fixed size, padding, background bound to AccentBrush via ElementName -->
                <Border x:Name="IconBg"
                        Width="44" Height="44"
                        CornerRadius="10"
                        Padding="10"
                        Background="{DynamicResource AccentBrush}">

                    <!-- CHANGED: Removed Canvas+ScaleTransform, using simple Viewbox with Stretch -->
                    <Viewbox>
                        <!-- CHANGED: Fill=White so icon is always visible on colored background -->
                        <!-- CHANGED: ElementName=Root for reliable binding instead of AncestorType -->
                        <!-- CHANGED: Added Stretch=Uniform so icon scales correctly -->
                        <Path x:Name="IconPath"
                              Stroke="White"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Data="{StaticResource IconWeb}"/>
                    </Viewbox>

                </Border>

                <!-- CHANGED: FontSize from 18 to 14 — 18 was too large for a stat card -->
                <!-- Name + Type stack -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock x:Name="NameText"
                               Text="E-commerce Platform"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    
                    <TextBlock x:Name="TypeText"
                               Text="Web App"
                               FontSize="12"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>

            </Grid>

            <!-- ROW 2: Divider -->
            <Border Grid.Row="1"
                    Height="1"
                    Background="{DynamicResource BorderDefaultBrush}"
                    VerticalAlignment="Center"/>


            <!-- ROW 3: Priority + DueDate + DaysLeft  -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- COLUMN 0: Priority -->
                <StackPanel Grid.Column="0" Margin="0,0,12,0">

                    <TextBlock Text="Priority"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                    <Border Height="4"/>

                    <!-- PriorityBadge -->
                    <components:PriorityBadge x:Name="PriorityBadge" 
                                              Margin="0,3,0,0" 
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"
                                              Status="Critical"/>


                </StackPanel>

                <Border Grid.Column="1"/>

                <!-- COLUMN 1: Grade -->
                <StackPanel Grid.Column="2" Margin="0,0,8,0">
                    <TextBlock Text="Due Date"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                    <Border Height="4"/>

                    <TextBlock x:Name="DueDateText"
                               Text="May 15"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,6,0,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

                <Border Grid.Column="3"/>

                <!-- COLUMN 2: DaysLeft -->
                <StackPanel Grid.Column="4">
                    <TextBlock Text="Days Left"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>

                    <Border Height="4"/>

                    <TextBlock x:Name="DaysLeftText"
                               Text="3d left"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,6,0,0"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>

            </Grid>

            <!-- ROW 2: Divider -->
            <Border Grid.Row="3"
                    Height="1"
                    Background="{DynamicResource BorderDefaultBrush}"
                    VerticalAlignment="Center"/>

            <!-- COLUMN 0: Progress -->
            <StackPanel Grid.Row="4" Margin="0,0,12,0">
                <Grid Margin="0,0,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Progress"
                               FontSize="11"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    <TextBlock x:Name="ProgressText"
                               Text="91.99 %"
                               Grid.Column="1"
                               FontSize="11"
                               Foreground="{DynamicResource AccentBrush}"/>
                </Grid>

                <!-- Progress Bar -->
                <components:ProgressBar x:Name="ProgressFill"
                                        Margin="0,8,0,0"
                                        ProgressWidth="91.99"/>

            </StackPanel>

            <!-- ROW 2: Divider -->
            <Border Grid.Row="5"
                    Height="1"
                    Background="{DynamicResource BorderDefaultBrush}"
                    VerticalAlignment="Center"/>

            <!-- ROW 5: Status + Butt -->
            <Grid Grid.Row="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Status Badge -->
                <!-- Use StatusBadge component instead of manual Border+TextBlock -->
                <components:StatusBadge x:Name="CategoryStatus"
                                        VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">

                    <!-- Edit Button -->
                    <Button x:Name="EditBtn"
                            Width="32" Height="32"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,6,0">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{DynamicResource AccentLightBrush}"
                                        CornerRadius="8">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="24" Height="24">
                                            <Path x:Name="EditIcon1"
                                                  Data="M11 4H4C3.46957 4 2.96086 4.21071 2.58579 4.58579C2.21071 4.96086 2 5.46957 2 6V20C2 20.5304 2.21071 21.0391 2.58579 21.4142C2.96086 21.7893 3.46957 22 4 22H18C18.5304 22 19.0391 21.7893 19.4142 21.4142C19.7893 21.0391 20 20.5304 20 20V13"
                                                  Stroke="{DynamicResource AccentBrush}"
                                                  StrokeThickness="2" Fill="Transparent"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Path x:Name="EditIcon2"
                                                  Data="M18.5 2.50001C18.8978 2.10219 19.4374 1.87869 20 1.87869C20.5626 1.87869 21.1022 2.10219 21.5 2.50001C21.8978 2.89784 22.1213 3.43741 22.1213 4.00001C22.1213 4.56262 21.8978 5.10219 21.5 5.50001L12 15L8 16L9 12L18.5 2.50001Z"
                                                  Stroke="{DynamicResource AccentBrush}"
                                                  StrokeThickness="2" Fill="Transparent"
                                                  StrokeLineJoin="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd"        Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter TargetName="EditIcon1" Property="Stroke"     Value="White"/>
                                        <Setter TargetName="EditIcon2" Property="Stroke"     Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Delete Button -->
                    <Button x:Name="DeleteBtn"
                            Width="32" Height="32"
                            BorderThickness="0"
                            Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{DynamicResource ErrorLightBrush}"
                                        CornerRadius="8">
                                    <Viewbox Width="14" Height="14">
                                        <Canvas Width="24" Height="24">
                                            <Path x:Name="DeleteIcon1"
                                                  Data="M3 6H5H21"
                                                  Stroke="{DynamicResource ErrorBrush}"
                                                  StrokeThickness="2" Fill="Transparent"
                                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                                            <Path x:Name="DeleteIcon2"
                                                  Data="M19 6V20C19 20.5304 18.7893 21.0391 18.4142 21.4142C18.0391 21.7893 17.5304 22 17 22H7C6.46957 22 5.96086 21.7893 5.58579 21.4142C5.21071 21.0391 5 20.5304 5 20V6M8 6V4C8 3.46957 8.21071 2.96086 8.58579 2.58579C8.96086 2.21071 9.46957 2 10 2H14C14.5304 2 15.0391 2.21071 15.4142 2.58579C15.7893 2.96086 16 3.46957 16 4V6"
                                                  Stroke="{DynamicResource ErrorBrush}"
                                                  StrokeThickness="2" Fill="Transparent"
                                                  StrokeLineJoin="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd"          Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                        <Setter TargetName="DeleteIcon1" Property="Stroke"     Value="White"/>
                                        <Setter TargetName="DeleteIcon2" Property="Stroke"     Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>

            </Grid>

        </Grid>


    </Border>
    
</UserControl>
