<UserControl x:Class="TaskManagerUI.Controls.Components.StatCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:TaskManagerUI.Controls.Components"
             mc:Ignorable="d"
             x:Name="Root">

    <Grid>

        <!-- Accent strip: right side, no corner radius needed -->
        <Border x:Name="AccentStrip"
            Background="{Binding AccentBrush, ElementName=Root}"
            HorizontalAlignment="Right"
            Width="28"
                Margin="0,0,2,1"
            CornerRadius="0,12,12,0"
            Panel.ZIndex="0"/>

        <!-- Card covers the strip's left edge with its own rounded corners -->
            <Border x:Name="CardBorder"
                    Background="{DynamicResource CardBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderDefaultBrush}"
                    BorderThickness="1,1,1,1"
                    CornerRadius="12"
                    Padding="20"
                    Margin="0,-1,4,-1"
                    Panel.ZIndex="1">

                <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="20"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="IconBg"
                        Width="44" Height="44"
                        CornerRadius="10"
                        Padding="10"
                        Background="{Binding AccentBrush, ElementName=Root}">
                        <Viewbox>
                            <Path x:Name="IconPath"
                              Stroke="White"
                              StrokeThickness="2"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Fill="Transparent"
                              Stretch="Uniform"
                              Data="{Binding Icon, ElementName=Root}"/>
                        </Viewbox>
                    </Border>

                    <TextBlock x:Name="TitleText"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextWrapping="Wrap"
                           Margin="12,0,0,0"/>
                </Grid>

                <Grid Grid.Row="1"/>

                <Grid Grid.Row="2">
                    <StackPanel HorizontalAlignment="Center" Orientation="Vertical">
                        <TextBlock x:Name="ValueText"
                               HorizontalAlignment="Center"
                               FontSize="36"
                               FontWeight="Bold"
                               Foreground="{Binding AccentBrush, ElementName=Root}"
                               Margin="0,0,0,6"/>
                        <TextBlock x:Name="LabelText"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               FontWeight="Normal"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                </Grid>
            </Grid>

        </Border>

    </Grid>

</UserControl>