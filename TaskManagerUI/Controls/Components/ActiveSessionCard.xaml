<UserControl x:Class="TaskManagerUI.Controls.Components.ActiveSessionCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:components="clr-namespace:TaskManagerUI.Controls.Components"
             mc:Ignorable="d"
             x:Name="Root">

    <Border Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="20">

        <Border.Effect>
            <DropShadowEffect x:Name="CardShadow"
                              Color="#10000000"
                              BlurRadius="20"
                              ShadowDepth="2"
                              Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Row 0: Header -->
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <!-- Row 2: Task Title + Subtitle -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <!-- Row 4: Timer + Buttons -->
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <!-- Row 6: ProgressBar + Status -->
            </Grid.RowDefinitions>

            <!-- Row 0: Header -->
            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Left: Title -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal">
                    <TextBlock Text="⚡"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="0,0,6,0"/>
                    <TextBlock Text="Active Session"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Right: Close Button -->
                <Button x:Name="CloseBtn"
                        Grid.Column="1"
                        Width="30" Height="30"
                        BorderThickness="0"
                        Cursor="Hand"
                        ToolTip="Close">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{DynamicResource CardHoverBackgroundBrush}"
                                    CornerRadius="8">
                               
                                <Path Data="{StaticResource IconClose}"
                                      Fill="{DynamicResource TextMutedBrush}"
                                      x:Name="CloseIcon"
                                      Width="14" Height="14"
                                      Stroke="White" StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      Stretch="Uniform"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd"        Property="Background" Value="{DynamicResource ErrorLightBrush}"/>
                                    <Setter TargetName="CloseIcon" Property="Fill"       Value="{DynamicResource ErrorBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd"        Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                    <Setter TargetName="CloseIcon" Property="Fill"       Value="White"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>

            <!-- Row 1: Divider -->
            <Border Grid.Row="1"
                    Height="1"
                    Background="{DynamicResource BorderDefaultBrush}"
                    VerticalAlignment="Center"/>

            <!-- Row 2: Task Title + Subtitle -->
            <StackPanel Grid.Row="2">
                <TextBlock x:Name="TaskTitleText"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="SubtitleText"
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Row 4: Timer + Pause/Stop Buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Elapsed Time -->
                <TextBlock x:Name="ElapsedTimeText"
                           Text="00:00:00"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"
                           FontFamily="Consolas"/>

                <!-- Pause + Stop Buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- Pause Button -->
                    <components:TimerButton x:Name="PauseBtn" 
                                            Margin="2"
                                            State="Pause"/>

                    <!-- Stop Button -->
                    <components:TimerButton x:Name="StopBtn" 
                                            Margin="2"
                                            State="Stop"/>

                </StackPanel>
            </Grid>

            <!-- Row 6: ProgressBar + Status -->
            <Grid Grid.Row="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Progress Bar -->
                    <components:ProgressBar x:Name="SessionProgress"
                                            Grid.Column="0"
                                            ProgressWidth="0"
                                            VerticalAlignment="Center"
                                            Margin="0,0,8,0"/>

                    <!-- Progress Text -->
                    <TextBlock x:Name="ProgressTextBlock"
                               Grid.Column="1"
                               VerticalAlignment="Center"
                               Text="0%"
                               Foreground="{DynamicResource AccentBrush}"/>
                </Grid>



                <!-- Running Status + StatusBadge -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Existing Running Status (keep as is) -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal">
                        <Ellipse x:Name="RunningDot"
                                 Width="8" Height="8"
                                 Fill="{DynamicResource SuccessBrush}"
                                 VerticalAlignment="Center"
                                 Margin="0,0,6,0"/>
                        <TextBlock x:Name="StatusText"
                                   Text="Running"
                                   FontSize="11"
                                   Foreground="{DynamicResource SuccessBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- StatusBadge on the right -->
                    <components:StatusBadge x:Name="SessionStatusBadge"
                                            Grid.Column="1"
                                            Status="InProgress"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Center"/>
                </Grid>
            </Grid>

        </Grid>
    </Border>
</UserControl>