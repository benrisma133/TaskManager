<UserControl x:Class="TaskManagerUI.Controls.Components.ActiveSessionCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:components="clr-namespace:TaskManagerUI.Controls.Components"
             mc:Ignorable="d"
             x:Name="Root">

    <Border Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Padding="20">

        <Border.Effect>
            <DropShadowEffect x:Name="CardShadow"
                              Color="#10000000"
                              BlurRadius="20"
                              ShadowDepth="2"
                              Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Row 0: Header -->
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <!-- Row 2: Task Title + Subtitle -->
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
                <!-- Row 4: Timer + Buttons -->
                <RowDefinition Height="10"/>
                <RowDefinition Height="Auto"/>
                <!-- Row 6: ProgressBar + Status -->
            </Grid.RowDefinitions>

            <!-- Row 0: Header -->
            <StackPanel Grid.Row="0"
                        Orientation="Horizontal">
                <TextBlock Text="⚡"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="0,0,6,0"/>
                <TextBlock Text="Active Session"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Row 1: Divider -->
            <Border Grid.Row="1"
                    Height="1"
                    Background="{DynamicResource BorderDefaultBrush}"
                    VerticalAlignment="Center"/>

            <!-- Row 2: Task Title + Subtitle -->
            <StackPanel Grid.Row="2">
                <TextBlock x:Name="TaskTitleText"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <TextBlock x:Name="SubtitleText"
                           FontSize="12"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,4,0,0"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>

            <!-- Row 4: Timer + Pause/Stop Buttons -->
            <Grid Grid.Row="4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Elapsed Time -->
                <TextBlock x:Name="ElapsedTimeText"
                           Text="00:00:00"
                           FontSize="28"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"
                           VerticalAlignment="Center"
                           FontFamily="Consolas"/>

                <!-- Pause + Stop Buttons -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- Pause Button -->
                    <Button x:Name="PauseBtn"
                            Width="36" Height="36"
                            BorderThickness="0"
                            Cursor="Hand"
                            Margin="0,0,8,0"
                            ToolTip="Pause">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{DynamicResource AccentLightBrush}"
                                        CornerRadius="8">
                                    <TextBlock x:Name="PauseIcon"
                                               Text="⏸"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd"        Property="Background" Value="{DynamicResource AccentBrush}"/>
                                        <Setter TargetName="PauseIcon" Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Stop Button -->
                    <Button x:Name="StopBtn"
                            Width="36" Height="36"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Stop">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                        Background="{DynamicResource ErrorLightBrush}"
                                        CornerRadius="8">
                                    <TextBlock x:Name="StopIcon"
                                               Text="⏹"
                                               FontSize="14"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ErrorBrush}"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd"       Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                        <Setter TargetName="StopIcon" Property="Foreground" Value="White"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ErrorBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>
            </Grid>

            <!-- Row 6: ProgressBar + Status -->
            <Grid Grid.Row="6">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Progress Bar -->
                <components:ProgressBar x:Name="SessionProgress"
                                        Grid.Row="0"
                                        ProgressWidth="0"
                                        Margin="0"/>

                <!-- Running Status -->
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal">
                    <Ellipse x:Name="RunningDot"
                             Width="8" Height="8"
                             Fill="{DynamicResource SuccessBrush}"
                             VerticalAlignment="Center"
                             Margin="0,0,6,0"/>
                    <TextBlock x:Name="StatusText"
                               Text="Running"
                               FontSize="11"
                               Foreground="{DynamicResource SuccessBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

        </Grid>
    </Border>
</UserControl>