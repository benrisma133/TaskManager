<UserControl x:Class="TaskManagerUI.Controls.Components.ProgressBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:TaskManagerUI.Controls.Components"
             mc:Ignorable="d" >
    <Grid x:Name="Root" Margin="0,8,0,0">
        <!-- Background track -->
        <Border Height="8"
            Background="{DynamicResource BorderDefaultBrush}"
            CornerRadius="4"/>

        <!-- Filled portion -->
        <Border x:Name="ProgressFill"
            Height="8"
            Background="{DynamicResource AccentBrush}"
            CornerRadius="4"
            HorizontalAlignment="Left"
            Width="0"/>
    </Grid>
</UserControl>
