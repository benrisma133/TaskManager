<UserControl x:Class="TaskManagerUI.Controls.Components.SessionCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d"
             x:Name="Root">

    <Border Background="{DynamicResource CardHoverBackgroundBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="14,12"
            MinWidth="120">

        <StackPanel>

            <!-- Time -->
            <TextBlock x:Name="StartTimeText"
                       FontSize="14"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"/>

            <!-- Duration -->
            <TextBlock x:Name="DurationText"
                       FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,4,0,0"/>

            <!-- Notes -->
            <TextBlock x:Name="NotesText"
                       FontSize="11"
                       Foreground="{DynamicResource TextMutedBrush}"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="140"
                       Margin="0,6,0,0"
                       Visibility="Collapsed"/>

        </StackPanel>

    </Border>

</UserControl>