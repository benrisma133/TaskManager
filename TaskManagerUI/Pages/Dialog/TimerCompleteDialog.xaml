<Window x:Class="TaskManagerUI.Pages.Dialog.TimerCompleteDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
        Width="480" Height="auto"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True">

    <Grid Margin="8">
        <Border CornerRadius="16"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.4"/>
            </Border.Effect>

            <StackPanel Margin="32,28">

                <!-- ── Icon + Title ── -->
                <StackPanel HorizontalAlignment="Center"
                            Margin="0,0,0,20">
                    <Border Width="56" Height="56"
                            CornerRadius="28"
                            Background="{DynamicResource SuccessLightBrush}"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,14">
                        <fa:IconImage Icon="Check"
                                      Width="24" Height="24"
                                      Foreground="{DynamicResource SuccessBrush}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                    </Border>

                    <TextBlock Text="Time's Up!"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center"/>

                    <TextBlock x:Name="TaskTitleText"
                               FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               TextAlignment="Center"
                               Margin="0,6,0,0"/>
                </StackPanel>

                <!-- ── Divider ── -->
                <Border Height="1"
                        Background="{DynamicResource BorderDefaultBrush}"
                        Margin="0,0,0,20"/>

                <!-- ── Error Box ── -->
                <Border x:Name="ErrorBox"
                        Background="{DynamicResource ErrorLightBrush}"
                        BorderBrush="{DynamicResource ErrorBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14,10"
                        Margin="0,0,0,16"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorText"
                               Foreground="{DynamicResource ErrorBrush}"
                               FontSize="12"
                               TextWrapping="Wrap"/>
                </Border>

                <!-- ── Radio Options ── -->
                <TextBlock Text="What would you like to do?"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,0,14"/>

                <!-- Option 1 — Mark as Done -->
                <Border x:Name="MarkDoneBorder"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="16,12"
                        Margin="0,0,0,10"
                        Cursor="Hand"
                        MouseDown="MarkDoneBorder_MouseDown">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton x:Name="MarkDoneRadio"
                                     GroupName="Action"
                                     IsChecked="True"
                                     VerticalAlignment="Center"
                                     Margin="0,0,12,0"
                                     Click="Radio_Click"/>
                        <StackPanel>
                            <TextBlock Text="Mark as Done"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                            <TextBlock Text="Close this task and mark it as completed."
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Option 2 — Add More Time -->
                <Border x:Name="AddTimeBorder"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="2"
                        CornerRadius="10"
                        Padding="16,12"
                        Margin="0,0,0,16"
                        Cursor="Hand"
                        MouseDown="AddTimeBorder_MouseDown">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <RadioButton x:Name="AddTimeRadio"
                                         GroupName="Action"
                                         IsChecked="False"
                                         VerticalAlignment="Center"
                                         Margin="0,0,12,0"
                                         Click="Radio_Click"/>
                            <StackPanel>
                                <TextBlock Text="Add More Time"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="Extend the estimated time and keep working."
                                           FontSize="12"
                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                           Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Minutes input — hidden by default -->
                        <StackPanel x:Name="ExtraMinutesPanel"
                                    Margin="36,14,0,0"
                                    Visibility="Collapsed">
                            <TextBlock Text="How many extra minutes?"
                                       FontSize="12"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBox x:Name="ExtraMinutesInput"
                                     Height="38"
                                     FontSize="14"
                                     Padding="10,0"
                                     VerticalContentAlignment="Center"
                                     Background="{DynamicResource SurfaceCardBrush}"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     BorderBrush="{DynamicResource BorderDefaultBrush}"
                                     BorderThickness="1"
                                     MaxLength="3"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- ── Buttons ── -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">

                    <Button x:Name="CancelBtn"
                            Content="Cancel"
                            Width="110" Height="40"
                            Margin="0,0,10,0"
                            Cursor="Hand"
                            Click="Cancel_Click"
                            Style="{DynamicResource GhostButtonStyle}"/>

                    <Button x:Name="SaveBtn"
                            Content="Save"
                            Width="110" Height="40"
                            Cursor="Hand"
                            Click="Save_Click"
                            Style="{DynamicResource PrimaryButtonStyle}"/>

                </StackPanel>

            </StackPanel>
        </Border>
    </Grid>
</Window>