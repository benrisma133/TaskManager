<UserControl x:Class="TaskManagerUI.Pages.Categories.CategoriesPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cards="clr-namespace:TaskManagerUI.Controls.Cards"
             Loaded="CategoriesPage_Loaded"
             SizeChanged="CategoriesPage_SizeChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ TOP BAR ═══════════ -->
        <Border Grid.Row="0" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <!-- Search + Filter -->
                    <ColumnDefinition Width="*"/>
                    <!-- Spacer -->
                    <ColumnDefinition Width="Auto"/>
                    <!-- Add Button -->
                </Grid.ColumnDefinitions>

                <!-- Search Box + Filter Combo -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">

                    <!-- Search Box -->
                    <Border Background="{DynamicResource InputBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="8"
                            Height="42"
                            Margin="0,0,16,0">
                        <Grid Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Search Icon -->
                            <Viewbox Width="16" Height="16"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="{StaticResource IconSearch}"
                                          Stroke="{DynamicResource TextMutedBrush}"
                                          StrokeThickness="2"
                                          Fill="Transparent"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>

                            <!-- Search TextBox -->
                            <TextBox x:Name="SearchBox"
                                     Grid.Column="1"
                                     MinWidth="200"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextPrimaryBrush}"
                                     CaretBrush="{DynamicResource AccentBrush}"
                                     FontSize="14"
                                     VerticalAlignment="Center"
                                     TextChanged="SearchBox_TextChanged"/>

                            <!-- Placeholder -->
                            <TextBlock x:Name="SearchPlaceholder"
                                       Grid.Column="1"
                                       Text="Search categories..."
                                       FontSize="14"
                                       Foreground="{DynamicResource TextPlaceholderBrush}"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"/>
                        </Grid>
                    </Border>

                    <!-- Filter Label + ComboBox -->
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <TextBlock Text="Filter by:"
                                   FontSize="14"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>

                        <ComboBox x:Name="TypeFilterCombo"
                                  Width="150"
                                  Height="42"
                                  SelectedIndex="0"
                                  Style="{DynamicResource ModernComboBox}"
                                  SelectionChanged="TypeFilterCombo_SelectionChanged">
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="All Types"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Project"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Task"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Course"/>
                        </ComboBox>
                    </StackPanel>

                </StackPanel>

                <!-- Add Button -->
                <Button Grid.Column="2"
                        x:Name="AddBtn"
                        Height="42"
                        Padding="16,0"
                        Cursor="Hand"
                        BorderThickness="0"
                        Background="{DynamicResource AccentBrush}"
                        Click="AddBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="+"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextOnAccentBrush}"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Add Category"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextOnAccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource AccentHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                    Value="{DynamicResource AccentPressedBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>
        </Border>

        <!-- ═══════════ CONTENT ═══════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,0,16,16">
            <Grid>

                <!-- Skeleton Loading -->
                <UniformGrid x:Name="SkeletonPanel"
                             Columns="3"
                             Visibility="Visible">
                    <!-- 6 skeleton cards -->
                    <Border Margin="8" Height="180" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}">
                        <Border.OpacityMask>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="White" Offset="0"/>
                                <GradientStop Color="Transparent" Offset="0.5"/>
                                <GradientStop Color="White" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.OpacityMask>
                    </Border>
                    <Border Margin="8" Height="180" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="180" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="180" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="180" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="180" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="180" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="180" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="180" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                </UniformGrid>

                <!-- Empty State -->
                <StackPanel x:Name="EmptyState"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="0,80"
                            Visibility="Collapsed">
                    <TextBlock Text="🗂️"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>
                    <TextBlock Text="No categories found"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Add your first category to get started"
                               FontSize="14"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Cards Panel -->
                <UniformGrid x:Name="CardsPanel"
                             Columns="3"
                             Margin="8,0"
                             VerticalAlignment="Top"
                             Visibility="Collapsed"/>

            </Grid>
        </ScrollViewer>

        <!-- ═══════════ TOTAL FOOTER ═══════════ -->
        <Border Grid.Row="2"
            Background="{DynamicResource SidebarBackgroundBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="0,1,0,0"
            CornerRadius="0,0,12,12"
            Padding="24,12"
                Height="53">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Total Count -->
                <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center">
                    <TextBlock Text="Total:"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           Margin="0,0,6,0"/>
                    <TextBlock x:Name="TotalCountText"
                           Text="0"
                           FontSize="13"
                           FontWeight="Bold"
                           Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="categories"
                           FontSize="13"
                           Foreground="{DynamicResource TextMutedBrush}"
                           Margin="6,0,0,0"/>
                </StackPanel>

                <!-- Showing Results (optional) -->
                <TextBlock x:Name="FilterResultText"
                       Grid.Column="2"
                       Text="Showing all"
                       FontSize="12"
                       Foreground="{DynamicResource TextMutedBrush}"
                       VerticalAlignment="Center"/>

            </Grid>
        </Border>

    </Grid>
</UserControl>