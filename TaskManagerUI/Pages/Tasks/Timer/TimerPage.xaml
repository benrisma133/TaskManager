<UserControl x:Class="TaskManagerUI.Pages.Tasks.Timer.TimerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:TaskManagerUI.Controls.Components"
             xmlns:fa="clr-namespace:FontAwesome.Sharp;assembly=FontAwesome.Sharp"
             Loaded="TimerPage_Loaded"
             Unloaded="TimerPage_Unloaded">

    <Grid Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Back Button -->
            <RowDefinition Height="*"/>
            <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- ROW 0 — Back Button                                     -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Padding="24,16"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="0,0,0,1">

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="BackBtn" Grid.Column="0"
                        Cursor="Hand"
                        BorderThickness="0"
                        Background="Transparent"
                        HorizontalAlignment="Left"
                        Click="BackBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    CornerRadius="8"
                                    Padding="10,6">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <fa:IconImage Icon="ArrowLeft"
                                                  Width="14"
                                                  Height="14"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  Margin="0,0,8,0"/>
                                    <TextBlock Text="Back to Tasks"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd"
                                            Property="Background"
                                            Value="{DynamicResource AccentHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Button x:Name="DoneBtn" Grid.Column="2"
                        Cursor="Hand"
                        BorderThickness="0"
                        Background="Transparent"
                        HorizontalAlignment="Left"
                        Click="DoneBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="Transparent"
                                    CornerRadius="8"
                                    Padding="10,6">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <fa:IconImage Icon="Check"
                                                  Width="14"
                                                  Height="14"
                                                  Foreground="{DynamicResource TextSecondaryBrush}"
                                                  Margin="0,0,8,0"/>
                                    <TextBlock Text="Mark as Done"
                                               FontSize="14"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd"
                                            Property="Background"
                                            Value="{DynamicResource SuccessBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
            
        </Border>

        <!-- ═══════════════════════════════════════════════════════ -->
        <!-- ROW 1 — Main Content                                    -->
        <!-- ═══════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="32,24">

                <!-- ── TOP : Task Info + Timer ────────────────────── -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Task Info -->
                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center">

                        <TextBlock x:Name="TaskTitleText"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal"
                                    Margin="0,8,0,0">

                            <TextBlock x:Name="ProjectTitleText"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>

                            <!-- Dot separator -->
                            <Ellipse Width="4" Height="4"
                                     Fill="{DynamicResource TextMutedBrush}"
                                     Margin="8,0"
                                     VerticalAlignment="Center"/>

                            <TextBlock x:Name="PriorityText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       VerticalAlignment="Center"/>

                            <!-- Dot separator -->
                            <Ellipse Width="4" Height="4"
                                     Fill="{DynamicResource TextMutedBrush}"
                                     Margin="8,0"
                                     VerticalAlignment="Center"/>

                            <TextBlock x:Name="StatusText"
                                       FontSize="13"
                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>

                        </StackPanel>
                    </StackPanel>

                    <!-- Timer Control -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource SurfaceCardBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="16"
                            Padding="20">

                        <Grid>
                            <components:TimerControl x:Name="Timer"
                                                     Started="Timer_Started"
                                                     Paused="Timer_Paused"
                                                     Ticked="Timer_Ticked"
                                                     Completed="Timer_Completed"
                                                     Stopped="Timer_Stopped"/>

                            <TextBlock x:Name="StatusLabel" 
                                       Text="Completed" 
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Visibility="Collapsed"/>

                        </Grid>
                        
                        

                        
                    </Border>

                </Grid>

                <!-- ── DIVIDER ─────────────────────────────────────── -->
                <Border Height="1"
                        Background="{DynamicResource BorderDefaultBrush}"
                        Margin="0,0,0,24"/>

                <!-- ── DESCRIPTION ────────────────────────────────── -->
                <StackPanel x:Name="DescriptionPanel"
                            Margin="0,0,0,24"
                            Visibility="Collapsed">

                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,10">
                        <fa:IconImage Icon="AlignLeft"
                                      Width="14"
                                      Height="14"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      Margin="0,0,8,0"/>
                        <TextBlock Text="Description"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <TextBlock x:Name="DescriptionText"
                               FontSize="14"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextWrapping="Wrap"
                               LineHeight="22"/>

                    <!-- ── DIVIDER ───────────────────────────────── -->
                    <Border Height="1"
                            Background="{DynamicResource BorderDefaultBrush}"
                            Margin="0,24,0,0"/>

                </StackPanel>

                <!-- ── STATS ROW ──────────────────────────────────── -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Estimated -->
                    <Border Grid.Column="0"
                            Background="{DynamicResource SurfaceCardBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16,14"
                            Margin="0,0,8,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                <fa:IconImage Icon="Clock"
                                              Width="12"
                                              Height="12"
                                              Foreground="{DynamicResource TextMutedBrush}"
                                              Margin="0,0,6,0"/>
                                <TextBlock Text="Estimated"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="EstimatedText"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Due Date -->
                    <Border Grid.Column="1"
                            Background="{DynamicResource SurfaceCardBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16,14"
                            Margin="8,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                <fa:IconImage Icon="CalendarDay"
                                              Width="12"
                                              Height="12"
                                              Foreground="{DynamicResource TextMutedBrush}"
                                              Margin="0,0,6,0"/>
                                <TextBlock Text="Due Date"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock x:Name="DueDateText"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Progress -->
                    <Border Grid.Column="2"
                            Background="{DynamicResource SurfaceCardBrush}"
                            BorderBrush="{DynamicResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="16,14"
                            Margin="8,0,0,0">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                <fa:IconImage Icon="ChartSimple"
                                              Width="12"
                                              Height="12"
                                              Foreground="{DynamicResource TextMutedBrush}"
                                              Margin="0,0,6,0"/>
                                <TextBlock Text="Progress"
                                           FontSize="12"
                                           Foreground="{DynamicResource TextMutedBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,0,0,6">
                                <TextBlock x:Name="ProgressText"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                <TextBlock Text="%"
                                           FontSize="16"
                                           FontWeight="Bold"
                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                           Margin="2,0,0,0"/>
                            </StackPanel>
                            <components:ProgressBar x:Name="ProgressBarControl"
                                                    ProgressWidth="0"/>
                        </StackPanel>
                    </Border>

                </Grid>

                <!-- ── DIVIDER ─────────────────────────────────────── -->
                <Border Height="1"
                        Background="{DynamicResource BorderDefaultBrush}"
                        Margin="0,0,0,24"/>

                <!-- ── TODAY'S SESSIONS ───────────────────────────── -->
                <StackPanel>

                    <StackPanel Orientation="Horizontal"
                                Margin="0,0,0,16">
                        <fa:IconImage Icon="Stopwatch"
                                      Width="14"
                                      Height="14"
                                      Foreground="{DynamicResource TextSecondaryBrush}"
                                      Margin="0,0,8,0"/>
                        <TextBlock Text="Time Logged Today"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>

                        <!-- Total today badge -->
                        <Border Background="{DynamicResource AccentBrush}"
                                CornerRadius="8"
                                Padding="8,3"
                                Margin="12,0,0,0"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="TotalTodayText"
                                       Text="0 min"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextOnAccentBrush}"/>
                        </Border>
                    </StackPanel>

                    <!-- Session Cards -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel x:Name="SessionsPanel"
                                    Orientation="Horizontal"/>
                    </ScrollViewer>

                    <!-- Empty Sessions -->
                    <TextBlock x:Name="NoSessionsText"
                               Text="No sessions logged today. Start the timer!"
                               FontSize="13"
                               Foreground="{DynamicResource TextMutedBrush}"
                               Margin="0,8,0,0"
                               Visibility="Visible"/>

                </StackPanel>

            </StackPanel>
        </ScrollViewer>

    </Grid>
</UserControl>