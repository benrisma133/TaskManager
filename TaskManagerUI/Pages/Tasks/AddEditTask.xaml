<Window x:Class="TaskManagerUI.Pages.Tasks.AddEditTask"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:inputs="clr-namespace:TaskManagerUI.Controls.Inputs"
        xmlns:components="clr-namespace:TaskManagerUI.Controls.Components"
        Width="540" Height="700"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Window.Resources>

        <Style x:Key="MessageBox" TargetType="Border">
            <Setter Property="Padding"      Value="16,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin"       Value="0,0,0,16"/>
        </Style>

        <Style x:Key="ErrorBox" TargetType="Border" BasedOn="{StaticResource MessageBox}">
            <Setter Property="Background"      Value="{DynamicResource ErrorLightBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ErrorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SuccessBox" TargetType="Border" BasedOn="{StaticResource MessageBox}">
            <Setter Property="Background"      Value="{DynamicResource SuccessLightBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SweetButton" TargetType="Button">
            <Setter Property="Foreground"      Value="{DynamicResource TextOnAccentBrush}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource ErrorLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource ErrorBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>

    </Window.Resources>

    <Grid Margin="8">
        <Border CornerRadius="16"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="55"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <!-- ═══════════ HEADER ═══════════ -->
                <Border Grid.Row="0"
                        CornerRadius="16,16,0,0"
                        Background="{DynamicResource HeaderBackgroundBrush}"
                        MouseDown="Header_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="16,0">
                            <Viewbox Width="20" Height="20"
                                     Margin="0,0,10,0"
                                     VerticalAlignment="Center">
                                <Path Fill="{DynamicResource AccentBrush}"
                                      Stretch="Uniform"
                                      Data="{StaticResource IconTasks}"/>
                            </Viewbox>
                            <TextBlock x:Name="WindowTitle"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButtonStyle}"
                                Click="Close_Click"
                                Margin="6,10">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="24" Height="24">
                                    <Path Data="{StaticResource IconClose}"
                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                          StrokeThickness="2.5"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>

                <!-- ═══════════ BODY ═══════════ -->
                <ScrollViewer x:Name="MainScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0,0,4,0">
                    <StackPanel Margin="32,24,32,8">

                        <!-- Form Title + Subtitle -->
                        <TextBlock x:Name="FormTitle"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,4"/>

                        <TextBlock x:Name="FormSubtitle"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,24"/>

                        <!-- Error Message -->
                        <Border x:Name="ErrorMessageBox"
                                Style="{StaticResource ErrorBox}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           FontSize="13"
                                           Margin="0,0,0,4">
                                    ⚠️ Please fix the following errors:
                                </TextBlock>
                                <TextBlock x:Name="ErrorMessageText"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Success Message -->
                        <Border x:Name="SuccessMessageBox"
                                Style="{StaticResource SuccessBox}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           FontSize="13"
                                           Margin="0,0,0,4">
                                    ✓ Saved successfully!
                                </TextBlock>
                                <TextBlock x:Name="SuccessMessageText"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Task Title -->
                        <inputs:ModernInput x:Name="TaskTitle"
                                            Label="Task Title"
                                            Placeholder="Enter the task title"
                                            IsRequired="True"
                                            MinLength="2"
                                            Margin="0,0,0,20"
                                            TextChanged="TaskTitle_TextChanged"/>

                        <!-- Description -->
                        <inputs:TextArea x:Name="TaskDescription"
                                         Label="Description"
                                         Placeholder="Describe this task... (optional)"
                                         AreaHeight="100"
                                         ShowCharacterCount="True"
                                         MaxLength="2000"
                                         Margin="0,0,0,20"/>

                        <!-- ── AddNew only: Project ComboBox ── -->
                        <StackPanel x:Name="ProjectPanel" Visibility="Visible">
                            <TextBlock Text="Project" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="TaskProject"
                                      Style="{DynamicResource ModernComboBox}"
                                      Margin="0,0,0,20"/>
                        </StackPanel>

                        <!-- ── AddNew only: Status Badge (Todo) ── -->
                        <StackPanel x:Name="StatusBadgePanel" Visibility="Visible">
                            <TextBlock Text="Status" Style="{StaticResource LabelStyle}"/>
                            <components:StatusBadge x:Name="DefaultStatusBadge"
                                                    Status="Todo"
                                                    Margin="0,0,0,20"
                                                    HorizontalAlignment="Left"/>
                        </StackPanel>

                        <!-- ── Update only: Project Title (read-only) ── -->
                        <StackPanel x:Name="ProjectReadOnlyPanel" Visibility="Collapsed">
                            <TextBlock Text="Project" Style="{StaticResource LabelStyle}"/>
                            <TextBlock x:Name="ProjectReadOnlyText"
                                       FontSize="14"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       Margin="0,0,0,20"/>
                        </StackPanel>

                        <!-- ── Update only: Status ComboBox ── -->
                        <StackPanel x:Name="StatusComboPanel" Visibility="Collapsed">
                            <TextBlock Text="Status" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="TaskStatus"
                                      Style="{DynamicResource ModernComboBox}"
                                      Margin="0,0,0,20">
                                <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Todo"/>
                                <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="InProgress"/>
                                <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Cancelled"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- Priority -->
                        <TextBlock Text="Priority" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="TaskPriority"
                                  Style="{DynamicResource ModernComboBox}"
                                  Margin="0,0,0,20">
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Low"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Medium"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="High"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Critical"/>
                        </ComboBox>

                        <!-- Due Date -->
                        <components:ModernDatePicker x:Name="TaskDueDate"
                                                     Label="Due Date"
                                                     YearFrom="2026"
                                                     AllowPastDates="False"
                                                      YearTo="2036"
                                                      Margin="0,0,0,20"/>

                        <!-- Estimated Minutes -->
                        <inputs:ModernInput x:Name="TaskEstimatedMinutes"
                                            Label="Estimated Minutes"
                                            Placeholder="e.g. 90 (optional)"
                                            ValidationType="Numeric"
                                            Margin="0,0,0,20"/>

                    </StackPanel>
                </ScrollViewer>

                <!-- ═══════════ FOOTER ═══════════ -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,20,0">

                        <Button Width="120" Height="40"
                                Background="{DynamicResource TextMutedBrush}"
                                Style="{StaticResource SweetButton}"
                                Click="Clear_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="{StaticResource IconClose}"
                                              Stroke="White"
                                              StrokeThickness="2.5"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Clear" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Width="120" Height="40"
                                Background="{DynamicResource AccentBrush}"
                                Margin="10,0,0,0"
                                Style="{StaticResource SweetButton}"
                                Click="Save_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="{StaticResource IconCheck}"
                                              Stroke="White"
                                              StrokeThickness="2.5"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Save" Margin="8,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>