<UserControl x:Class="TaskManagerUI.Pages.Tasks.TasksPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:cards="clr-namespace:TaskManagerUI.Controls.Cards"
             Loaded="TasksPage_Loaded"
             SizeChanged="TasksPage_SizeChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════ TOP BAR ═══════════ -->
        <Border Grid.Row="0" Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search Box + Filters -->
                <StackPanel Grid.Column="0"
            Orientation="Horizontal"
            HorizontalAlignment="Left">

                    <!-- Search Box -->
                    <Border Background="{DynamicResource InputBackgroundBrush}"
            BorderBrush="{DynamicResource BorderDefaultBrush}"
            BorderThickness="1"
            CornerRadius="8"
            Height="42"
            Margin="0,0,16,0">
                        <Grid Margin="12,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Viewbox Width="16" Height="16"
                     Margin="0,0,8,0"
                     VerticalAlignment="Center">
                                <Canvas Width="24" Height="24">
                                    <Path Data="{StaticResource IconSearch}"
                          Stroke="{DynamicResource TextMutedBrush}"
                          StrokeThickness="2"
                          Fill="Transparent"
                          StrokeStartLineCap="Round"
                          StrokeEndLineCap="Round"/>
                                </Canvas>
                            </Viewbox>

                            <TextBox x:Name="SearchBox"
                     Grid.Column="1"
                     MinWidth="200"
                     Background="Transparent"
                     BorderThickness="0"
                     Foreground="{DynamicResource TextPrimaryBrush}"
                     CaretBrush="{DynamicResource AccentBrush}"
                     FontSize="14"
                     VerticalAlignment="Center"
                     TextChanged="SearchBox_TextChanged"/>

                            <TextBlock x:Name="SearchPlaceholder"
                       Grid.Column="1"
                       Text="Search tasks..."
                       FontSize="14"
                       Foreground="{DynamicResource TextPlaceholderBrush}"
                       VerticalAlignment="Center"
                       IsHitTestVisible="False"/>
                        </Grid>
                    </Border>

                    <!-- Priority Filter -->
                    <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center"
                Margin="0,0,16,0">
                        <TextBlock Text="Priority:"
                   FontSize="14"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="PriorityFilterCombo"
                  Width="130"
                  Height="42"
                  SelectedIndex="0"
                  Style="{DynamicResource ModernComboBox}"
                  SelectionChanged="PriorityFilterCombo_SelectionChanged">
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="All"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Low"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Medium"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="High"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Critical"/>
                        </ComboBox>
                    </StackPanel>

                    <!-- Status Filter -->
                    <StackPanel Orientation="Horizontal"
                VerticalAlignment="Center">
                        <TextBlock Text="Status:"
                   FontSize="14"
                   Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center"
                   Margin="0,0,8,0"/>
                        <ComboBox x:Name="StatusFilterCombo"
                  Width="130"
                  Height="42"
                  SelectedIndex="0"
                  Style="{DynamicResource ModernComboBox}"
                  SelectionChanged="StatusFilterCombo_SelectionChanged">
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="All"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Todo"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="InProgress"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Done"/>
                            <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Cancelled"/>
                        </ComboBox>
                    </StackPanel>

                </StackPanel>

                <!-- Add Button -->
                <Button Grid.Column="1"
                        x:Name="AddBtn"
                        Height="42"
                        Padding="16,0"
                        Cursor="Hand"
                        BorderThickness="0"
                        Background="{DynamicResource AccentBrush}"
                        Click="AddBtn_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <TextBlock Text="+"
                                               FontSize="18"
                                               FontWeight="Bold"
                                               Foreground="{DynamicResource TextOnAccentBrush}"
                                               Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Add Task"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextOnAccentBrush}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource AccentHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background"
                                            Value="{DynamicResource AccentPressedBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

            </Grid>
        </Border>

        <!-- ═══════════ CONTENT ═══════════ -->
        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="16,0,16,16">
            <Grid>

                <!-- Skeleton Loading -->
                <UniformGrid x:Name="SkeletonPanel"
                             Columns="3"
                             Visibility="Visible">
                    <Border Margin="8" Height="200" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="200" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="200" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="200" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="200" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                    <Border Margin="8" Height="200" CornerRadius="12"
                            Background="{DynamicResource CardBackgroundBrush}"/>
                </UniformGrid>

                <!-- Empty State -->
                <StackPanel x:Name="EmptyState"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Margin="0,80"
                            Visibility="Collapsed">
                    <TextBlock Text="✅"
                               FontSize="48"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,16"/>
                    <TextBlock Text="No tasks found"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Add your first task to get started"
                               FontSize="14"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Cards Panel -->
                <UniformGrid x:Name="CardsPanel"
                             Columns="3"
                             Margin="8,0"
                             VerticalAlignment="Top"
                             Visibility="Collapsed"/>

            </Grid>
        </ScrollViewer>

        <!-- ═══════════ FOOTER ═══════════ -->
        <Border Grid.Row="2"
        Background="{DynamicResource SidebarBackgroundBrush}"
        BorderBrush="{DynamicResource BorderDefaultBrush}"
        BorderThickness="0,1,0,0"
        CornerRadius="0,0,12,12"
        Padding="24,8"
        Height="53">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Total Count -->
                <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">
                    <TextBlock Text="Total:"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       Margin="0,0,6,0"/>
                    <TextBlock x:Name="TotalCountText"
                       Text="0"
                       FontSize="13"
                       FontWeight="Bold"
                       Foreground="{DynamicResource AccentBrush}"/>
                    <TextBlock Text="tasks"
                       FontSize="13"
                       Foreground="{DynamicResource TextMutedBrush}"
                       Margin="6,0,0,0"/>
                </StackPanel>

                <!-- Pagination -->
                <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center">

                    <!-- Previous -->
                    <Button x:Name="PrevBtn"
                    Width="32" Height="32"
                    Cursor="Hand"
                    BorderThickness="0"
                    Margin="0,0,8,0"
                    Click="PrevBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                    <Viewbox Width="12" Height="12">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M15 18L9 12L15 6"
                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                          StrokeThickness="2.5"
                                          Fill="Transparent"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentLightBrush}"/>
                                        <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!-- Page Numbers -->
                    <StackPanel x:Name="PageNumbersPanel"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"/>

                    <!-- Next -->
                    <Button x:Name="NextBtn"
                    Width="32" Height="32"
                    Cursor="Hand"
                    BorderThickness="0"
                    Margin="8,0,0,0"
                    Click="NextBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd"
                                Background="{DynamicResource InputBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                                    <Viewbox Width="12" Height="12">
                                        <Canvas Width="24" Height="24">
                                            <Path Data="M9 18L15 12L9 6"
                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                          StrokeThickness="2.5"
                                          Fill="Transparent"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"/>
                                        </Canvas>
                                    </Viewbox>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource AccentLightBrush}"/>
                                        <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsEnabled" Value="False">
                                        <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                </StackPanel>

                <!-- Filter Result -->
                <TextBlock x:Name="FilterResultText"
                   Grid.Column="2"
                   FontSize="12"
                   Foreground="{DynamicResource TextMutedBrush}"
                   VerticalAlignment="Center"
                   HorizontalAlignment="Right"/>

            </Grid>
        </Border>

    </Grid>
</UserControl>