<Window x:Class="TaskManagerUI.Pages.Projects.AddEditProject"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:inputs="clr-namespace:TaskManagerUI.Controls.Inputs"
        xmlns:components="clr-namespace:TaskManagerUI.Controls.Components"
        Width="540" Height="720"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Window.Resources>

        <Style x:Key="MessageBox" TargetType="Border">
            <Setter Property="Padding"      Value="16,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin"       Value="0,0,0,16"/>
        </Style>

        <Style x:Key="ErrorBox" TargetType="Border" BasedOn="{StaticResource MessageBox}">
            <Setter Property="Background"      Value="{DynamicResource ErrorLightBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource ErrorBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SuccessBox" TargetType="Border" BasedOn="{StaticResource MessageBox}">
            <Setter Property="Background"      Value="{DynamicResource SuccessLightBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource SuccessBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style x:Key="SweetButton" TargetType="Button">
            <Setter Property="Foreground"      Value="{DynamicResource TextOnAccentBrush}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.7"/>
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.97" ScaleY="0.97"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="6"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource ErrorLightBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background"
                                        Value="{DynamicResource ErrorBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin"     Value="0,0,0,8"/>
        </Style>

    </Window.Resources>

    <Grid Margin="8">
        <Border CornerRadius="16"
                Background="{DynamicResource CardBackgroundBrush}"
                BorderBrush="{DynamicResource BorderDefaultBrush}"
                BorderThickness="1"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect Color="#000000"
                                  BlurRadius="20"
                                  ShadowDepth="0"
                                  Opacity="0.4"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="55"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <!-- ═══════════ HEADER ═══════════ -->
                <Border Grid.Row="0"
                        CornerRadius="16,16,0,0"
                        Background="{DynamicResource HeaderBackgroundBrush}"
                        MouseDown="Header_MouseDown">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="48"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="16,0">
                            <Viewbox Width="20" Height="20"
                                     Margin="0,0,10,0"
                                     VerticalAlignment="Center">
                                <Path Fill="{DynamicResource AccentBrush}"
                                      Stretch="Uniform"
                                      Data="{StaticResource IconProjects}"/>
                            </Viewbox>
                            <TextBlock x:Name="WindowTitle"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="1"
                                Style="{StaticResource CloseButtonStyle}"
                                Click="Close_Click"
                                Margin="6,10">
                            <Viewbox Width="14" Height="14">
                                <Canvas Width="24" Height="24">
                                    <Path Data="{StaticResource IconClose}"
                                          Stroke="{DynamicResource TextSecondaryBrush}"
                                          StrokeThickness="2.5"
                                          StrokeLineJoin="Round"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                        </Button>
                    </Grid>
                </Border>

                <!-- ═══════════ BODY ═══════════ -->
                <ScrollViewer x:Name="MainScrollViewer"
                              Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0,0,4,0">
                    <StackPanel Margin="32,24,32,8">

                        <!-- Form Title + Subtitle -->
                        <TextBlock x:Name="FormTitle"
                                   FontSize="22"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   Margin="0,0,0,4"/>

                        <TextBlock x:Name="FormSubtitle"
                                   FontSize="13"
                                   Foreground="{DynamicResource TextMutedBrush}"
                                   Margin="0,0,0,24"/>

                        <!-- Error Message -->
                        <Border x:Name="ErrorMessageBox"
                                Style="{StaticResource ErrorBox}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           FontSize="13"
                                           Margin="0,0,0,4">
                                    ⚠️ Please fix the following errors:
                                </TextBlock>
                                <TextBlock x:Name="ErrorMessageText"
                                           Foreground="{DynamicResource ErrorBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Success Message -->
                        <Border x:Name="SuccessMessageBox"
                                Style="{StaticResource SuccessBox}"
                                Visibility="Collapsed">
                            <StackPanel>
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           FontSize="13"
                                           Margin="0,0,0,4">
                                    ✓ Saved successfully!
                                </TextBlock>
                                <TextBlock x:Name="SuccessMessageText"
                                           Foreground="{DynamicResource SuccessBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Title -->
                        <inputs:ModernInput x:Name="ProjectTitle"
                                            Label="Project Title"
                                            Placeholder="Enter the project title"
                                            IsRequired="True"
                                            MinLength="2"
                                            Margin="0,0,0,20"
                                            TextChanged="ProjectTitle_TextChanged"/>

                        <!-- Description -->
                        <inputs:TextArea x:Name="ProjectDescription"
                                         Label="Description"
                                         Placeholder="Describe this project... (optional)"
                                         AreaHeight="100"
                                         ShowCharacterCount="True"
                                         MaxLength="1000"
                                         Margin="0,0,0,20"/>

                        <!-- Category -->
                        <TextBlock Text="Category" Style="{StaticResource LabelStyle}"/>
                        <ComboBox x:Name="ProjectCategory"
                                  Style="{DynamicResource ModernComboBox}"
                                  Margin="0,0,0,20"/>

                        <!-- Priority + Status side by side -->
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Priority -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Priority" Style="{StaticResource LabelStyle}"/>
                                <ComboBox x:Name="ProjectPriority"
                                          Style="{DynamicResource ModernComboBox}"
                                          SelectedIndex="1">
                                    <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Low"/>
                                    <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Medium"/>
                                    <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="High"/>
                                    <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Critical"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- Status -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Status" Style="{StaticResource LabelStyle}"/>
                                <ComboBox x:Name="ProjectStatus"
                                          Style="{DynamicResource ModernComboBox}"
                                          SelectedIndex="0">
                                    <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Active"/>
                                    <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Paused"/>
                                    <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Completed"/>
                                    <ComboBoxItem Style="{StaticResource ModernComboBoxItem}" Content="Archived"/>
                                </ComboBox>
                            </StackPanel>
                        </Grid>

                        <!-- Start Date + Due Date side by side -->
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="16"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Start Date -->
                            <components:ModernDatePicker x:Name="ProjectStartDate"
                                                          Grid.Row="0"
                                                          Label="Start Date"
                                                          AllowPastDates="True"
                                                          YearFrom="2020"
                                                          YearTo="2036"
                                                          Margin="0,0,0,20"/>

                            <!-- Due Date -->
                            <components:ModernDatePicker x:Name="ProjectDueDate"
                                                          Grid.Row="2"
                                                          Label="Due Date"
                                                          AllowPastDates="False"
                                                          YearFrom="2024"
                                                          YearTo="2036"
                                                          Margin="0,0,0,20"/>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>

                <!-- ═══════════ FOOTER ═══════════ -->
                <Border Grid.Row="2"
                        BorderBrush="{DynamicResource BorderDefaultBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,20,0">

                        <Button Width="120" Height="40"
                                Background="{DynamicResource TextMutedBrush}"
                                Style="{StaticResource SweetButton}"
                                Click="Clear_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="{StaticResource IconClose}"
                                              Stroke="White"
                                              StrokeThickness="2.5"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Clear"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Width="120" Height="40"
                                Background="{DynamicResource AccentBrush}"
                                Margin="10,0,0,0"
                                Style="{StaticResource SweetButton}"
                                Click="Save_Click">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Viewbox Width="16" Height="16">
                                    <Canvas Width="24" Height="24">
                                        <Path Data="{StaticResource IconCheck}"
                                              Stroke="White"
                                              StrokeThickness="2.5"
                                              StrokeLineJoin="Round"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent"/>
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="Save"
                                           Margin="8,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                    </StackPanel>
                </Border>

            </Grid>
        </Border>
    </Grid>
</Window>