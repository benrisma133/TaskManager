<Application x:Class="TaskManagerUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:TaskManagerUI"
             StartupUri="MainWindow.xaml">

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Helpers/Colors.xaml"/>
                <ResourceDictionary Source="/Helpers/Styles.xaml"/>
                <ResourceDictionary Source="/Helpers/ModernComboBoxItem.xaml"/>
                <ResourceDictionary Source="/Assets/Icons.xaml"/>
            </ResourceDictionary.MergedDictionaries>
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily"
                Value="/Assets/Fonts/#JetBrains Mono"/>
            </Style>
        </ResourceDictionary>
        
    </Application.Resources>

</Application>
